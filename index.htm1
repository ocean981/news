<!DOCTYPE html>
<html>
<head>
    <title>国际新闻</title>
    <style>
        body { font-family: Arial; max-width: 800px; margin: auto; padding: 20px; background: #f5f5f5; }
        h1 { color: #333; }
        .news-item { background: white; border-radius: 8px; padding: 15px; margin-bottom: 15px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .title { font-size: 18px; font-weight: bold; }
        .title a { color: #0366d6; text-decoration: none; }
        .title a:hover { text-decoration: underline; }
        .source { color: #666; font-size: 14px; margin-top: 5px; }
        .loading { text-align: center; padding: 50px; }
    </style>
</head>
<body>
    <h1>🌍 最新国际新闻</h1>
    <div id="news" class="loading">正在加载新闻...</div>

    <script>
        // 使用免费的 RSS 转 JSON 服务（不需要 API Key）
        const RSS_URL = 'https://api.rss2json.com/v1/api.json?rss_url=' + 
            encodeURIComponent('http://feeds.bbci.co.uk/news/world/rss.xml');
        
        fetch(RSS_URL)
            .then(response => response.json())
            .then(data => {
                if (data.items && data.items.length > 0) {
                    const newsDiv = document.getElementById('news');
                    newsDiv.className = '';  // 移除 loading 样式
                    newsDiv.innerHTML = '';
                    
                    data.items.slice(0, 10).forEach(item => {
                        const newsItem = document.createElement('div');
                        newsItem.className = 'news-item';
                        newsItem.innerHTML = `
                            <div class="title"><a href=" " target="_blank">${item.title}</a ></div>
                            <div class="source">${item.pubDate.split(' ')[0]}</div>
                        `;
                        newsDiv.appendChild(newsItem);
                    });
                } else {
                    document.getElementById('news').innerHTML = '无法加载新闻，请稍后再试。';
                }
            })
            .catch(error => {
                document.getElementById('news').innerHTML = '出错了，请刷新页面重试。';
            });
    </script>
</body>
</html>
